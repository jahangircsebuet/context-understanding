HiOhAooJUTSfx5JOBWI'}], None, None, None, [], False, 'Jahangir Alam\u200eBangladesh Student Association SIUC (BSA)'])dict_values(['3380470898856988', 'যখন নিজের দেশকে বিশ্বের সামনে তুলে ধরার সুযোগ থাকে, আমাদের সবার প্রয়াস হয় নিজেদের কৃষ্টি-সংস্কৃতির, আমাদের প্রিয় বাংলাদেশের সুন্দর একটা প্রতিচ্ছবির বহিঃপ্রকাশ ঘটানো।\n\nফেব্রুয়ারী ৮ তারিখে ইন্টারন্যাশনাল ফুড ফেস্টিভ্যাল এবং ফেব্রুয়ারী ১০ তারিখে ইন্টারন্যাশনাল কালচারাল ফেস্টিভ্যালে আমরা সবাই বাংলাদেশের পক্ষ হয়ে অংশগ্রহণ করছি।\n\nফুড ফেস্টিভ্যালের রান্নার প্রস্তুতির জন্য ফেব্রুয়ারী ৬ অথবা ৭ যেকোনো একটা দিনে বিকাল ৪.৩০ থেকে রাত ৯ টা পর্যন্ত সময় নির্ধারণ করা হয়েছে, নির্ধারিত চূড়ান্ত দিন এবং সময় পরবর্তীতে জানিয়ে দেওয়া হবে। রান্নার চমকের অংশ হিসেবে স্টার্টার, মেইন ডিশ এবং ডেজার্ট থাকবে। রান্নার কাজে সহযোগিতার জন্য আপনাদের সবার উপস্থিতি কাম্য।\n\n১০ তারিখের কালচারাল ফেস্টিভ্যালে নাচ, গান, কিংবা কোনো ছোট্ট শিশুর মুখে একটা ছড়া হয়ে যেতেই পারে। যারা আগ্রহী অবশ্যই আমাদেরকে জানাবেন। আমরা সবার অংশগ্রহণ কামনা করছি। ধন্যবাদ।', 'যখন নিজের দেশকে বিশ্বের সামনে তুলে ধরার সুযোগ থাকে, আমাদের সবার প্রয়াস হয় নিজেদের কৃষ্টি-সংস্কৃতির, আমাদের প্রিয় বাংলাদেশের সুন্দর একটা প্রতিচ্ছবির বহিঃপ্রকাশ ঘটানো।\n\nফেব্রুয়ারী ৮ তারিখে ইন্টারন্যাশনাল ফুড ফেস্টিভ্যাল এবং ফেব্রুয়ারী ১০ তারিখে ইন্টারন্যাশনাল কালচারাল ফেস্টিভ্যালে আমরা সবাই বাংলাদেশের পক্ষ হয়ে অংশগ্রহণ করছি।\n\nফুড ফেস্টিভ্যালের রান্নার প্রস্তুতির জন্য ফেব্রুয়ারী ৬ অথবা ৭ যেকোনো একটা দিনে বিকাল ৪.৩০ থেকে রাত ৯ টা পর্যন্ত সময় নির্ধারণ করা হয়েছে, নির্ধারিত চূড়ান্ত দিন এবং সময় পরবর্তীতে জানিয়ে দেওয়া হবে। রান্নার চমকের অংশ হিসেবে স্টার্টার, মেইন ডিশ এবং ডেজার্ট থাকবে। রান্নার কাজে সহযোগিতার জন্য আপনাদের সবার উপস্থিতি কাম্য।\n\n১০ তারিখের কালচারাল ফেস্টিভ্যালে নাচ, গান, কিংবা কোনো ছোট্ট শিশুর মুখে একটা ছড়া হয়ে যেতেই পারে। যারা আগ্রহী অবশ্যই আমাদেরকে জানাবেন। আমরা সবার অংশগ্রহণ কামনা করছি। ধন্যবাদ।', '', None, datetime.datetime(2023, 1, 23, 11, 32, 19), 1674495139, None, 'https://scontent-ord5-2.xx.fbcdn.net/m1/v/t6/An_UvxJXg9tdnLU3Y5qjPi0200MLilhzPXUgxzGjQzUMaNcmjdZA6anyrngvkdub33NZzZhd51fpCAEzNH