, None, '10160947379322871', ['10160947379322871'], False, 'Shujon Mehedi Hasan\u200eBangladesh Student Association SIUC (BSA)'])dict_values(['3221252268112186', 'আপনারা কি ফুটবল বা হাড়িভাঙ্গা খেলার জন্য প্রস্তুত?\nছোটদের জন্য থাকবে বস্তা-দৌড়!\nপটলাকের মেনু আসা শুরু হয়েছে। নওরীন ভাবি চিকেন বিরিয়ানি আনবেন, লাকি ভাবি বিফ বিরিয়ানি আনবেন। রনি ভাবি চটপটি আনবেন। নাফিসা ভাবি পায়েস আনবেন।\nআপনারাও কমেন্ট করে মেনু জানাতে পারেন।', 'আপনারা কি ফুটবল বা হাড়িভাঙ্গা খেলার জন্য প্রস্তুত?\nছোটদের জন্য থাকবে বস্তা-দৌড়!\nপটলাকের মেনু আসা শুরু হয়েছে। নওরীন ভাবি চিকেন বিরিয়ানি আনবেন, লাকি ভাবি বিফ বিরিয়ানি আনবেন। রনি ভাবি চটপটি আনবেন। নাফিসা ভাবি পায়েস আনবেন।\nআপনারাও কমেন্ট করে মেনু জানাতে পারেন।', '', None, datetime.datetime(2022, 7, 8, 14, 31, 2), 1657308662, 'https://scontent-ord5-1.xx.fbcdn.net/v/t39.30808-6/292594704_10160946748832871_4253968864741291082_n.jpg?stp=cp0_dst-jpg_e15_fr_q65&_nc_cat=108&ccb=1-7&_nc_sid=5f2048&efg=eyJpIjoidCJ9&_nc_ohc=pBKSQHeC7gYAX-KPAwA&tn=PKBvE-4fpoK4f5Ih&_nc_ht=scontent-ord5-1.xx&oh=00_AfAK_8nDBlQDRtqAxwNWn9GPLS_gcBUdn7QNrRyvqt6BHA&oe=65530BF3&manual_redirect=1', 'https://scontent-ord5-1.xx.fbcdn.net/v/t39.30808-6/292594704_10160946748832871_4253968864741291082_n.jpg?stp=cp0_dst-jpg_e15_p320x320_q65&_nc_cat=108&ccb=1-7&_nc_sid=5f2048&efg=eyJpIjoidCJ9&_nc_ohc=pBKSQHeC7gYAX-KPAwA&tn=PKBvE-4fpoK4f5Ih&_nc_ht=scontent-ord5-1.xx&oh=00_AfBDtUkGiF9pnh0BxLqaNHag0qhEAVQimApOj79Rxlyu4A&oe=65530BF3', ['https://scontent-ord5-1.xx.fbcdn.net/v/t39.30808-6/292594704_10160946748832871_4253968864741291082_n.jpg?stp=cp0_dst-jpg_e15_fr_q65&_nc_cat=108&ccb=1-7&_nc_sid=5f2048&efg=eyJpIjoidCJ9&_nc_ohc=pBKSQHeC7gYAX-KPAwA&tn=PKBvE-4fpoK4f5Ih&_nc_ht=scontent-ord5-1.xx&oh=00_AfAK_8nDBlQDRtqAxwNWn9GPLS_gcBUdn7QNrRyvqt6BHA&oe=65530BF3&manual_redirect=1'], ["May be an image of text that says 'SUMMER GET TOGETHER EID CELEBRATION POTLUCK Date: July 9, 2022 Saturday (5:30 PM) Venue: Evergreen Park, Carbondale Games Sack Race for Kids (6+) Football for Men Hari Vanga for Women Bangl