ends and family. Wish us good luck. :D', '', None, datetime.datetime(2022, 4, 28, 12, 28, 56), 1651166936, 'https://scontent-ord5-2.xx.fbcdn.net/v/t39.30808-6/279021064_1671422323193937_8295208624509037345_n.jpg?stp=cp0_dst-jpg_e15_fr_q65&_nc_cat=100&ccb=1-7&_nc_sid=5f2048&efg=eyJpIjoidCJ9&_nc_ohc=bGYPfVeFZPEAX_KsTes&_nc_ht=scontent-ord5-2.xx&oh=00_AfC6nt3Cdci3MxsrCTxL-kcvlrKJDtx8b4yzkLQpvaSMyA&oe=6552DBD1&manual_redirect=1', 'https://scontent-ord5-2.xx.fbcdn.net/v/t39.30808-6/279021064_1671422323193937_8295208624509037345_n.jpg?stp=cp0_dst-jpg_e15_p240x240_q65&_nc_cat=100&ccb=1-7&_nc_sid=5f2048&efg=eyJpIjoidCJ9&_nc_ohc=bGYPfVeFZPEAX_KsTes&_nc_ht=scontent-ord5-2.xx&oh=00_AfBKxWSPYgfZou2oQCDah4nJ4XL3wihNGslk8U2r1IWJYQ&oe=6552DBD1', ['https://scontent-ord5-2.xx.fbcdn.net/v/t39.30808-6/279021064_1671422323193937_8295208624509037345_n.jpg?stp=cp0_dst-jpg_e15_fr_q65&_nc_cat=100&ccb=1-7&_nc_sid=5f2048&efg=eyJpIjoidCJ9&_nc_ohc=bGYPfVeFZPEAX_KsTes&_nc_ht=scontent-ord5-2.xx&oh=00_AfC6nt3Cdci3MxsrCTxL-kcvlrKJDtx8b4yzkLQpvaSMyA&oe=6552DBD1&manual_redirect=1'], ['No photo description available.'], ['https://scontent-ord5-2.xx.fbcdn.net/v/t39.30808-6/279021064_1671422323193937_8295208624509037345_n.jpg?stp=cp0_dst-jpg_e15_p240x240_q65&_nc_cat=100&ccb=1-7&_nc_sid=5f2048&efg=eyJpIjoidCJ9&_nc_ohc=bGYPfVeFZPEAX_KsTes&_nc_ht=scontent-ord5-2.xx&oh=00_AfBKxWSPYgfZou2oQCDah4nJ4XL3wihNGslk8U2r1IWJYQ&oe=6552DBD1'], ['No photo description available.'], None, None, None, None, None, None, None, None, None, 9, 3, 0, 'https://m.facebook.com/groups/1590338747870221/permalink/3167674480136632/', None, [{'link': 'https://m.facebook.com/groups/1590338747870221/permalink/3167674480136632/?refid=18&paipv=0&eav=Afb7wJwY4f0Hs-YB8GVGCqgK5QDV87YXVH3sl0bJbpznkigD3e9ndNyS_OiFuDOFqi0', 'text': 'More'}, {'link': 'https://m.facebook.com/groups/1590338747870221/permalink/3167674480136632/?m_entstream_source=group&refid=18&_ft_=encrypted_tracking_data.0AY-ChK18J1jc24dlYnQESs9yukhIrnoLBC6We5HMHxOBULyhm5lsLSnn-