Sumaiya Binta Islam\u200eBangladesh Student Association SIUC (BSA)'])dict_values(['3324835744420504', 'শীতের আমেজের সাথে গরম ধোঁয়া উঠা ভাপা পিঠার সমীকরণ সবসময়ই দারুণ। বাঙ্গালিয়ানার এই ছন্দ ধরে রাখার জন্য বাংলাদেশ স্টুন্ডেন্ট এসোসিয়েশন এর পক্ষ থেকে আগামী সোমবার, ২১ নভেম্বর ২০২২ তারিখে পিঠা উৎসবের আয়োজন করা হবে। আপনারা সবাই আমন্ত্রিত।\n\nসম্ভাব্য সময় এবং ভেন্যু পরবর্তী পোস্টে জানিয়ে দেওয়া হবে।\n\nএটি একটি পটলাক অনুষ্ঠান। যারা পিঠা বানাতে আগ্রহী তারা কমেন্টে অথবা স্টুডেন্ট কমিটির যেকোনো সদস্যকে জানাবেন। ধন্যবাদ।', 'শীতের আমেজের সাথে গরম ধোঁয়া উঠা ভাপা পিঠার সমীকরণ সবসময়ই দারুণ। বাঙ্গালিয়ানার এই ছন্দ ধরে রাখার জন্য বাংলাদেশ স্টুন্ডেন্ট এসোসিয়েশন এর পক্ষ থেকে আগামী সোমবার, ২১ নভেম্বর ২০২২ তারিখে পিঠা উৎসবের আয়োজন করা হবে। আপনারা সবাই আমন্ত্রিত।\n\nসম্ভাব্য সময় এবং ভেন্যু পরবর্তী পোস্টে জানিয়ে দেওয়া হবে।\n\nএটি একটি পটলাক অনুষ্ঠান। যারা পিঠা বানাতে আগ্রহী তারা কমেন্টে অথবা স্টুডেন্ট কমিটির যেকোনো সদস্যকে জানাবেন। ধন্যবাদ।', '', None, datetime.datetime(2022, 11, 15, 21, 40, 25), 1668570025, 'https://scontent-ord5-2.xx.fbcdn.net/v/t39.30808-6/315871262_5548293361954199_2501576036696086062_n.jpg?stp=cp0_dst-jpg_e15_fr_q65&_nc_cat=110&ccb=1-7&_nc_sid=5f2048&efg=eyJpIjoidCJ9&_nc_ohc=K4j7KcLyOvUAX8Zlh7P&_nc_ht=scontent-ord5-2.xx&oh=00_AfAlBmO2m2rZP6do0qaG39LMe2QUt_cQeknUgW4_9o-pVA&oe=65532C28&manual_redirect=1', 'https://scontent-ord5-2.xx.fbcdn.net/v/t39.30808-6/315871262_5548293361954199_2501576036696086062_n.jpg?stp=cp0_dst-jpg_e15_p320x320_q65&_nc_cat=110&ccb=1-7&_nc_sid=5f2048&efg=eyJpIjoidCJ9&_nc_ohc=K4j7KcLyOvUAX8Zlh7P&_nc_ht=scontent-ord5-2.xx&oh=00_AfCsYE3b-9cGi5X3kgsf21vh35SfseRSQgb_8SDSYGA_oA&oe=65532C28', ['https://scontent-ord5-2.xx.fbcdn.net/v/t39.30808-6/315871262_5548293361954199_2501576036696086062_n.jpg?stp=cp0_dst-jpg_e15_fr_q65&_nc_cat=110&ccb=1-7&_nc_sid=5f2048&efg=eyJpIjoidCJ9&_nc_ohc=K4j7KcLyOvUAX8Zlh7P&_nc_ht=scontent-ord5-2.xx&oh=00_AfAlBmO2m2rZP6do0qaG39LMe2QUt_cQeknUgW4_9o-pVA&oe=65532C28&manual_redirect=1'], ['No photo description available.'], ['htt